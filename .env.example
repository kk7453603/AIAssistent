API_PORT=8080
LOG_LEVEL=info

POSTGRES_DSN=postgres://postgres:postgres@postgres:5432/assistant?sslmode=disable
NATS_URL=nats://nats:4222
NATS_SUBJECT=documents.ingest

OLLAMA_URL=http://ollama:11434
OLLAMA_GEN_MODEL=llama3.1:8b
# Planner model for agent tool selection (separate from generation model).
# Recommended: qwen3:14b for 16GB VRAM GPUs.
# If empty, uses OLLAMA_GEN_MODEL.
OLLAMA_PLANNER_MODEL=qwen3:14b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_PORT=11435
HOST_OLLAMA_HOST=host.docker.internal
HOST_OLLAMA_PORT=11434

# LLM Provider: "ollama" (default), "openai-compat", "groq", "together", "openrouter", "cerebras"
LLM_PROVIDER=ollama
LLM_PROVIDER_URL=
LLM_PROVIDER_KEY=
# Model for external LLM providers (if empty, uses OLLAMA_GEN_MODEL)
LLM_MODEL=

# Reranker provider: "fallback" (token-overlap, no GPU), "ollama", "openai-compat"
RERANKER_PROVIDER=fallback
RERANKER_PROVIDER_URL=
RERANKER_PROVIDER_KEY=
RERANKER_MODEL=

# Embedding Provider: "ollama" (default), "openai-compat"
EMBED_PROVIDER=ollama
EMBED_PROVIDER_URL=
EMBED_PROVIDER_KEY=

# Query expansion (multi-query retrieval)
QUERY_EXPANSION_ENABLED=false
QUERY_EXPANSION_COUNT=3

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=documents
QDRANT_MEMORY_COLLECTION=conversation_memory
# Embedding vector dimension. When set, collections are created at startup.
# nomic-embed-text=768, bge-m3=1024. Set to 0 to skip (collection created on first index).
QDRANT_EMBED_DIM=0

STORAGE_PATH=/data/storage
CHUNK_SIZE=900
CHUNK_OVERLAP=150
CHUNK_STRATEGY=fixed
RAG_TOP_K=5
RAG_RETRIEVAL_MODE=semantic
RAG_HYBRID_CANDIDATES=30
RAG_FUSION_STRATEGY=rrf
RAG_FUSION_RRF_K=60
RAG_RERANK_TOP_N=20

OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL_ID=paa-rag-v1
OPENAI_COMPAT_CONTEXT_MESSAGES=5
OPENAI_COMPAT_STREAM_CHUNK_CHARS=120
OPENAI_COMPAT_TOOL_TRIGGER_KEYWORDS=file,document,upload,attach,документ,файл,загрузи,вложение
AGENT_MODE_ENABLED=true
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=90
AGENT_PLANNER_TIMEOUT_SECONDS=20
AGENT_TOOL_TIMEOUT_SECONDS=30
AGENT_SHORT_MEMORY_MESSAGES=12
AGENT_SUMMARY_EVERY_TURNS=6
AGENT_MEMORY_TOP_K=4
AGENT_KNOWLEDGE_TOP_K=5
AGENT_INTENT_ROUTER_ENABLED=true
WORKER_METRICS_PORT=9090
API_RATE_LIMIT_RPS=40
API_RATE_LIMIT_BURST=80
API_BACKPRESSURE_MAX_IN_FLIGHT=64
API_BACKPRESSURE_WAIT_MS=250
RESILIENCE_BREAKER_ENABLED=true
RESILIENCE_RETRY_MAX_ATTEMPTS=3
RESILIENCE_RETRY_INITIAL_BACKOFF_MS=100
RESILIENCE_RETRY_MAX_BACKOFF_MS=400
RESILIENCE_RETRY_MULTIPLIER=2.0
RESILIENCE_BREAKER_MIN_REQUESTS=10
RESILIENCE_BREAKER_FAILURE_RATIO=0.5
RESILIENCE_BREAKER_OPEN_MS=30000
RESILIENCE_BREAKER_HALF_OPEN_MAX_CALLS=2
NATS_CONNECT_TIMEOUT_MS=2000
NATS_RECONNECT_WAIT_MS=2000
NATS_MAX_RECONNECTS=60
NATS_RETRY_ON_FAILED_CONNECT=true
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=ChangeMeGrafana123!

OPENWEBUI_ADMIN_EMAIL=admin@example.com
OPENWEBUI_ADMIN_PASSWORD=ChangeMeStrongPass123!
OPENWEBUI_ADMIN_NAME=Admin
OPENWEBUI_SECRET_KEY=replace-with-long-random-secret
OBSIDIAN_VAULTS_HOST_PATH=./obsidian_vaults

# --- OpenWebUI Pipe Function (RAG) ---
# The pipe function (paa_rag_pipe) replaces the old tool-based RAG.
# Files uploaded in OpenWebUI UI go through our ingest pipeline (NATS worker),
# and chat is proxied to /v1/chat/completions with built-in hybrid RAG.
# No extra configuration needed — Valves are configurable in OpenWebUI admin UI.

# --- Web Search (SearXNG) ---
WEB_SEARCH_ENABLED=true
WEB_SEARCH_URL=http://searxng:8080
WEB_SEARCH_LIMIT=5

# --- MCP (Model Context Protocol) ---
# MCP server exposes PAA tools (knowledge_search, web_search, obsidian_write, task_*)
# on /mcp endpoint for external clients (OpenWebUI, Claude Code, Cursor).
MCP_SERVER_ENABLED=true
# External MCP servers the agent can connect to (JSON array).
# Each entry: {"name":"...","transport":"stdio|sse|streamable-http","command":"...","args":[...],"url":"..."}
# All three servers below run as Docker Compose services and are reachable inside the network.
MCP_SERVERS=[{"name":"filesystem","transport":"streamable-http","url":"http://mcp-filesystem:3000/mcp"},{"name":"code-runner","transport":"streamable-http","url":"http://mcp-code-runner:3001/mcp"},{"name":"github","transport":"streamable-http","url":"http://mcp-github:3002/mcp"}]

# GitHub token for the MCP GitHub server (issues, PRs, repos, search).
# Create a PAT at https://github.com/settings/tokens with repo scope.
# GITHUB_TOKEN=ghp_...

ASSISTANT_OBSIDIAN_DEFAULT_INTERVAL_MINUTES=15
ASSISTANT_OBSIDIAN_POLL_SECONDS=30
ASSISTANT_OBSIDIAN_WAIT_READY=true
ASSISTANT_OBSIDIAN_SYNC_TIMEOUT_SECONDS=120
ASSISTANT_OBSIDIAN_SYNC_POLL_SECONDS=2

# --- Fallback LLM (при ошибке основного провайдера) ---
# LLM_FALLBACK_PROVIDER=ollama
# LLM_FALLBACK_URL=
# LLM_FALLBACK_KEY=
# LLM_FALLBACK_MODEL=

# --- Несколько провайдеров (выбор через UI dropdown) ---
# Список дополнительных провайдеров (через запятую).
# Каждый появится в OpenWebUI как отдельная модель "paa-<name>".
# LLM_EXTRA_PROVIDERS=huggingface,openrouter
# LLM_HUGGINGFACE_KEY=hf_...
# LLM_HUGGINGFACE_MODEL=Qwen/Qwen2.5-72B-Instruct
# LLM_OPENROUTER_KEY=sk-or-...
# LLM_OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# === Configuration examples ===
#
# --- Полностью локальный (рекомендуемый) ---
# OLLAMA_GEN_MODEL=qwen3.5:9b   (reranking + query expansion + generation)
# OLLAMA_EMBED_MODEL=bge-m3     (embeddings)
# RERANKER_PROVIDER=ollama       (LLM-based reranking через локальный Ollama)
# QUERY_EXPANSION_ENABLED=true
#
# --- Гибридный: embedding локально, LLM через OpenRouter ---
# LLM_PROVIDER=openai-compat
# LLM_PROVIDER_URL=https://openrouter.ai/api/v1
# LLM_PROVIDER_KEY=sk-or-...
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct-turbo
# RERANKER_PROVIDER=openai-compat
# RERANKER_PROVIDER_URL=https://openrouter.ai/api/v1
# RERANKER_PROVIDER_KEY=sk-or-...
# RERANKER_MODEL=meta-llama/llama-3.3-70b-instruct-turbo
#
# --- HuggingFace (бесплатные модели) ---
# LLM_PROVIDER=huggingface
# LLM_PROVIDER_KEY=hf_...
# LLM_MODEL=Qwen/Qwen2.5-72B-Instruct
# LLM_FALLBACK_PROVIDER=ollama
#
# --- OpenRouter (бесплатные модели) с fallback ---
# LLM_PROVIDER=openrouter
# LLM_PROVIDER_KEY=sk-or-...
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
# LLM_FALLBACK_PROVIDER=ollama
